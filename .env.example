# ============================================
# RabAi Mind 配置文件模板
# 复制此文件为 .env 并填入实际值
# ============================================

# ========== API 服务配置 ==========
API_HOST=0.0.0.0
API_PORT=8000
API_AUTH_ENABLED=false
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here_change_in_production
MAX_UPLOAD_SIZE=52428800

# ========== 火山引擎 API 配置 ==========
VOLCANO_API_KEY=your_volcano_api_key_here
VOLCANO_SECRET=your_volcano_secret_here
VOLCANO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_PROJECT_ID=your_project_id_here
VOLCANO_TEXT_MODEL=ep-20260303221115-dk4rt
VOLCANO_IMAGE_MODEL=ep-20260314123401-jwqhn
VOLCANO_TIMEOUT=120

# ========== Redis 配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=
REDIS_DB=0

# ========== OSS 配置 ==========
OSS_ENABLED=false
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# ========== PPT 生成配置 ==========
PPT_WIDTH=1600
PPT_HEIGHT=900
PPT_DEFAULT_SLIDES=10
PPT_MAX_SLIDES=30
PPT_ASPECT_RATIO=16:9
PPT_OUTPUT_FORMATS=pptx,pdf,images
PPT_TEMPLATE_DEFAULT=default
PPT_TEMPLATE_DIR=./templates
IMAGE_FALLBACK_STRATEGY=all

# ========== Agent 配置 ==========
AGENT_COORDINATOR_MAX_STEPS=30
AGENT_COORDINATOR_TIMEOUT=600
AGENT_OPTIMIZER_COMPRESSION_ENABLED=true
AGENT_OPTIMIZER_COMPRESS_QUALITY=80

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/rabai_mind.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ========== 任务队列配置 ==========
TASK_QUEUE_BACKEND=memory

# ========== CORS 配置 ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174

# ========== 路径配置 ==========
OUTPUT_DIR=./output
TEMPLATE_DIR=./templates
WORKSPACE_DIR=./workspace
SCHEMA_DIR=./schemas

# ========== MCP 服务配置 ==========
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_OKPPT_SERVER_PATH=
MCP_MAX_REQUEST_SIZE=10485760
MCP_HEARTBEAT_INTERVAL=30

# ========== 版本 ==========
VERSION=1.0.0
