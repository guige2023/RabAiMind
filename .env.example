# =============================================================================
# RabAi Mind — 环境变量配置示例
# =============================================================================
#
# 使用方法：
#   cp .env.example .env
#   # 编辑 .env 填写真实值
#
# 所有配置项均通过 src/config.py (Settings 类) 读取。
# config.yaml 仅作文档参考，不要直接编辑。
#
# =============================================================================

# ==================== 火山引擎 API（必填） ====================
VOLCANO_API_KEY=your-volcano-api-key-here
VOLCANO_SECRET=
VOLCANO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_PROJECT_ID=
VOLCANO_TEXT_MODEL=ep-20260303221115-dk4rt
VOLCANO_IMAGE_MODEL=ep-20260314123401-jwqhn
VOLCANO_TIMEOUT=120

# ==================== API 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_AUTH_ENABLED=false
JWT_SECRET=your-secret-key-change-in-production
API_KEY=
MAX_UPLOAD_SIZE=52428800

# ==================== MCP 服务配置 ====================
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_OKPPT_SERVER_PATH=/usr/local/bin/mcp-server-okppt
MCP_MAX_REQUEST_SIZE=10485760
MCP_HEARTBEAT_INTERVAL=30

# ==================== Redis 配置（可选） ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=
REDIS_DB=0

# ==================== OSS 配置（可选） ====================
OSS_ENABLED=false
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_BUCKET=rabai-mind-ppt
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# ==================== PPT 生成配置 ====================
PPT_WIDTH=1600
PPT_HEIGHT=900
PPT_ASPECT_RATIO=16:9
PPT_DEFAULT_SLIDES=10
PPT_MAX_SLIDES=30
PPT_OUTPUT_FORMATS=pptx,pdf,images
PPT_TEMPLATE_DEFAULT=default
PPT_TEMPLATE_DIR=./templates
PPT_SVG_VIEWBOX=0 0 1600 900
PPT_SVG_EMBED_IMAGES=true
PPT_SVG_OPTIMIZE_PATHS=true

# ==================== Agent 配置 ====================
AGENT_COORDINATOR_MAX_STEPS=30
AGENT_COORDINATOR_TIMEOUT=600
AGENT_QUALITY_SVG_SCHEMA_PATH=./schemas/svg_schema.json
AGENT_QUALITY_PPTX_VALIDATOR=libreoffice
AGENT_VOLCANO_TEXT_MAX_TOKENS=32000
AGENT_VOLCANO_IMAGE_MAX_SIZE=2048
AGENT_OPTIMIZER_COMPRESSION_ENABLED=true
AGENT_OPTIMIZER_COMPRESS_QUALITY=80

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=./logs/rabai_mind.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==================== 任务队列配置 ====================
TASK_QUEUE_BACKEND=memory

# ==================== CORS 配置 ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ==================== 路径配置 ====================
OUTPUT_DIR=./output
TEMPLATE_DIR=./templates
WORKSPACE_DIR=./workspace
SCHEMA_DIR=./schemas
