# RabAi Mind 环境变量配置示例
#
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ==================== 火山引擎配置 (必填) ====================
# 火山引擎 API 密钥
VOLCANO_API_KEY=your-api-key-here
# 火山引擎 API 密钥 (备用)
VOLCANO_SECRET=

# ==================== 火山引擎模型配置 ====================
# 文本生成模型 ID
TEXT_MODEL=ep-xxx
# 图片生成模型 ID
IMAGE_MODEL=ep-xxx
# API 端点
API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# ==================== OSS 配置 (可选) ====================
# OSS 端点
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
# OSS Bucket 名称
OSS_BUCKET=your-bucket-name
# OSS Access Key
OSS_ACCESS_KEY=your-access-key
# OSS Secret Key
OSS_SECRET_KEY=your-secret-key

# ==================== Redis 配置 (可选) ====================
# Redis 主机
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 密码 (如有)
REDIS_PASSWORD=
# Redis 完整连接 URL
REDIS_URL=redis://localhost:6379/0

# ==================== 服务配置 ====================
# API 服务端口
PORT=8000
# MCP 服务端口
MCP_PORT=8080

# ==================== 应用配置 ====================
# 输出目录
OUTPUT_DIR=./output
# 模板目录
TEMPLATE_DIR=./templates

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
