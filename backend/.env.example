# 应用配置
APP_NAME=RabAiMind API
DEBUG=true
API_PREFIX=/api/v1

# 数据库
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rabaimind

# Redis
REDIS_URL=redis://localhost:6379/0

# 百度云BOS配置
BOS_ENDPOINT=https://bj.bcebos.com
BOS_ACCESS_KEY_ID=your_access_key_id
BOS_SECRET_ACCESS_KEY=your_secret_access_key
BOS_BUCKET_NAME=rabaimind-files

# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Mini-Max API
MINIMAX_API_KEY=your_api_key_here
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.5

# Volcano Engine (火山引擎)
VOLCENGINE_ENDPOINT=https://ark.cn-beijing.volces.com
VOLCENGINE_REGION=cn-beijing
VOLCENGINE_ACCESS_KEY_ID=your_access_key_id
VOLCENGINE_SECRET_ACCESS_KEY=your_secret_access_key

# MCP Server
MCP_SERVER_URL=https://mcp.minimax.com/search
